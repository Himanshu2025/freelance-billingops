@page "/"
@page "/dashboard"
@rendermode InteractiveServer

@inject billingops.web.Services.AuthApiService AuthApiService

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<p class="text-muted">Welcome to BillingOps. This is a simple starting dashboard.</p>

<div class="card p-3" style="max-width: 600px;">
    <h5>Quick Actions</h5>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" href="/invoices">View Invoices</a>
        <a class="btn btn-outline-primary" href="/create-invoice">Create Invoice</a>
        <a class="btn btn-outline-secondary" href="/login">Login</a>
        <a class="btn btn-outline-secondary" href="/register">Register</a>
    </div>

    <button class="btn btn-link mt-3 p-0" @onclick="CheckSessionAsync">Check Session</button>

    @if (!string.IsNullOrWhiteSpace(sessionMessage))
    {
        <div class="alert @(isSessionError ? "alert-warning" : "alert-success") mt-3">
            @sessionMessage
        </div>
    }
</div>

@code {
    private string sessionMessage = string.Empty;
    private bool isSessionError;

    private async Task CheckSessionAsync()
    {
        var result = await AuthApiService.MeAsync();
        isSessionError = !result.Success;
        sessionMessage = result.Message;
    }
}
