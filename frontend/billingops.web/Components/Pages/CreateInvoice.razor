@page "/create-invoice"
@rendermode InteractiveServer

@inject billingops.web.Services.InvoiceApiService InvoiceApiService
@inject NavigationManager NavigationManager

<PageTitle>Create Invoice</PageTitle>

<h1>Create Invoice</h1>

<div class="card p-3" style="max-width: 700px;">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Client Name</label>
            <input class="form-control" @bind="request.ClientName" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Client Email</label>
            <input class="form-control" @bind="request.ClientEmail" />
        </div>

        <div class="col-12">
            <label class="form-label">Description</label>
            <textarea class="form-control" rows="3" @bind="request.Description"></textarea>
        </div>

        <div class="col-md-4">
            <label class="form-label">Amount</label>
            <input class="form-control" type="number" step="0.01" @bind="request.Amount" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Due Date</label>
            <InputDate class="form-control" @bind-Value="request.DueDate" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Status</label>
            <select class="form-select" @bind="request.Status">
                <option>Draft</option>
                <option>Sent</option>
                <option>Paid</option>
                <option>Overdue</option>
            </select>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" @onclick="CreateInvoiceAsync" disabled="@isLoading">Save Invoice</button>
        <a class="btn btn-outline-secondary" href="/invoices">Cancel</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") mt-3">
            @message
        </div>
    }
</div>

@code {
    private readonly billingops.web.Models.CreateInvoiceRequest request = new();
    private string message = string.Empty;
    private bool isError;
    private bool isLoading;

    private async Task CreateInvoiceAsync()
    {
        isLoading = true;
        message = string.Empty;

        var result = await InvoiceApiService.CreateInvoiceAsync(request);

        isLoading = false;
        isError = !result.Success;
        message = result.Message;

        if (result.Success)
        {
            NavigationManager.NavigateTo("/invoices");
        }
    }
}
