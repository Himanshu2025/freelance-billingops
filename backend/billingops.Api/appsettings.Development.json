{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=billingops.db"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Swagger": {
    "Enabled": true
  },
  "Http": {
    "UseHttpsRedirection": false
  },
  "DataProtection": {
    "KeysPath": "DataProtectionKeys"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }, 
  "AllowedHosts": "*"
}
