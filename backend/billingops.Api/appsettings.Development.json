{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=billingops.db"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Swagger": {
    "Enabled": true
  },
  "Http": {
    "UseHttpsRedirection": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "https://localhost:5173",
      "http://localhost:4173",
      "https://localhost:4173"
    ]
  },
  "DataProtection": {
    "KeysPath": "DataProtectionKeys"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }, 
  "AllowedHosts": "*"
}
